{
  "name": "chowmein",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",

    "check-types": "turbo run check-types",
    "format": "ultracite fix",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.15",
    "lefthook": "^2.1.1",
    "lint-staged": "^16.2.7",
    "turbo": "^2.8.9",
    "ultracite": "7.2.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "bun x ultracite fix"
    ]
  }
}
